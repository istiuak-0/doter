{
  "name": "doter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:build": "electron-builder",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "@editorjs/editorjs": "^2.31.5",
    "@nuxt/ui": "^4.6.0",
    "@vueuse/core": "^14.2.1",
    "iocraft": "^0.2.11",
    "vue": "beta",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "electron": "41.0.0",
    "electron-builder": "^26.8.1",
    "oxfmt": "^0.35.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "beta",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "appId": "com.doter.app",
    "productName": "Doter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}