{
  "name": "doter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -n vite,tsc,electron -c cyan,green,yellow \"vite\" \"tsc -p electron/tsconfig.json --watch\" \"pnpm electron:dev\"",
    "electron:dev": "wait-on tcp:5173 && wait-on dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "build": "run-s type-check build-only electron:compile electron:build",
    "build-only": "cross-env ELECTRON=true vite build",
    "electron:build": "electron-builder",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "format": "oxfmt src/"
  },
  "dependencies": {
    "iocraft": "^0.2.9",
    "vue": "beta",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "41.0.0",
    "electron-builder": "^26.8.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.35.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "beta",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vue-tsc": "^3.2.5",
    "wait-on": "^9.0.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "appId": "com.doter.app",
    "productName": "Doter",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}